@page "/results/{DocumentId:guid}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<SoWDbContext> DbFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="govuk-width-container">
    <main class="govuk-main-wrapper" id="main-content">
        @if (_result is not null)
        {
            <div class="app-results-toolbar">
                <a href="/" class="govuk-back-link">Back</a>
                <button class="govuk-button govuk-button--secondary"
                        @onclick="DownloadPdfAsync"
                        disabled="@_downloading">
                    @(_downloading ? "Generating…" : "Download improved document")
                </button>
            </div>
            <ResultsPanel Result="_result"
                          SuppressedSections="_suppressed"
                          OnSuppressedChanged="SaveSuppressedAsync"
                          OnSectionEdited="HandleSectionEdited"
                          OnVersionRestored="HandleVersionRestored"
                          OnVersionPreviewRequested="HandleVersionPreviewRequested"
                          OnPreviewCleared="ClearPreview"
                          VersionHistory="_versionHistory"
                          PreviewSectionIndex="_previewSectionIndex"
                          PreviewVersionNumber="_previewVersionNumber"
                          PreviewContent="@_previewContent" />
        }
    </main>
</div>

@code {
    [Parameter] public Guid DocumentId { get; set; }

    private IJSObjectReference? _module;
    private bool _downloading;
    private ImprovementResult? _result;
    private List<SectionEntity>? _sections;
    private readonly HashSet<int> _suppressed = [];
    private Dictionary<int, List<SectionVersionInfo>> _versionHistory = [];

    // Version preview state
    private int? _previewSectionIndex;
    private int? _previewVersionNumber;
    private string? _previewContent;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _sections = await db.Sections
            .Where(s => s.DocumentId == DocumentId)
            .Include(s => s.Versions)
            .OrderBy(s => s.SectionIndex)
            .ToListAsync();

        if (_sections.Count == 0)
        {
            Nav.NavigateTo("/", replace: true);
            return;
        }

        _result = new ImprovementResult
        {
            Sections = _sections.Select(s => new SectionResult
            {
                OriginalTitle = s.OriginalTitle,
                OriginalContent = s.OriginalContent,
                ImprovedContent = s.ImprovedContent,
                MatchedSection = s.MatchedSection,
                Explanation = s.Explanation,
                Unrecognised = s.Unrecognised,
                VersionCount = s.Versions.Count
            }).ToList()
        };

        foreach (var s in _sections.Where(s => s.Suppressed))
            _suppressed.Add(s.SectionIndex);

        _versionHistory = _sections.ToDictionary(
            s => s.SectionIndex,
            s => s.Versions
                .OrderBy(v => v.VersionNumber)
                .Select(v => new SectionVersionInfo(v.VersionNumber, v.CreatedAt))
                .ToList());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./Components/Pages/Results.razor.js");
    }

    private async Task HandleSectionEdited((int SectionIndex, string NewMarkdown) args)
    {
        var section = _sections!.First(s => s.SectionIndex == args.SectionIndex);
        var nextVersion = section.Versions.Count > 0
            ? section.Versions.Max(v => v.VersionNumber) + 1
            : 1;

        var version = new SectionVersionEntity
        {
            Id = Guid.NewGuid(),
            SectionId = section.Id,
            VersionNumber = nextVersion,
            Content = args.NewMarkdown,
            CreatedAt = DateTime.UtcNow
        };

        section.ImprovedContent = args.NewMarkdown;
        section.Versions.Add(version);

        await using var db = await DbFactory.CreateDbContextAsync();
        db.SectionVersions.Add(version);
        db.Attach(section).Property(s => s.ImprovedContent).IsModified = true;
        await db.SaveChangesAsync();

        _result!.Sections[args.SectionIndex].ImprovedContent = args.NewMarkdown;
        _result.Sections[args.SectionIndex].VersionCount = section.Versions.Count;

        _versionHistory[args.SectionIndex] = section.Versions
            .OrderBy(v => v.VersionNumber)
            .Select(v => new SectionVersionInfo(v.VersionNumber, v.CreatedAt))
            .ToList();
    }

    private async Task HandleVersionRestored((int SectionIndex, int VersionNumber) args)
    {
        var section = _sections!.First(s => s.SectionIndex == args.SectionIndex);
        var sourceVersion = section.Versions.First(v => v.VersionNumber == args.VersionNumber);
        ClearPreview();
        await HandleSectionEdited((args.SectionIndex, sourceVersion.Content));
    }

    private void HandleVersionPreviewRequested((int SectionIndex, int VersionNumber) args)
    {
        var section = _sections!.First(s => s.SectionIndex == args.SectionIndex);
        var version = section.Versions.FirstOrDefault(v => v.VersionNumber == args.VersionNumber);
        if (version is not null)
        {
            _previewSectionIndex = args.SectionIndex;
            _previewVersionNumber = args.VersionNumber;
            _previewContent = version.Content;
        }
    }

    private void ClearPreview()
    {
        _previewSectionIndex = null;
        _previewVersionNumber = null;
        _previewContent = null;
    }

    private async Task SaveSuppressedAsync()
    {
        if (_sections is null) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        foreach (var sec in _sections)
        {
            var shouldSuppress = _suppressed.Contains(sec.SectionIndex);
            if (sec.Suppressed != shouldSuppress)
            {
                sec.Suppressed = shouldSuppress;
                db.Attach(sec).Property(s => s.Suppressed).IsModified = true;
            }
        }
        await db.SaveChangesAsync();
    }

    private async Task DownloadPdfAsync()
    {
        if (_result is null || _module is null) return;

        _downloading = true;
        try
        {
            var suppressedSnapshot = _suppressed.ToHashSet();
            // Snapshot section content to avoid mutation during background PDF generation
            var sectionSnapshots = _result.Sections.Select(s => (s.OriginalTitle, s.OriginalContent, s.ImprovedContent, s.Unrecognised)).ToList();
            var snapshotResult = new ImprovementResult
            {
                Sections = sectionSnapshots.Select(s => new SectionResult
                {
                    OriginalTitle = s.OriginalTitle,
                    OriginalContent = s.OriginalContent,
                    ImprovedContent = s.ImprovedContent,
                    Unrecognised = s.Unrecognised
                }).ToList()
            };
            var pdfBytes = await Task.Run(() => PdfExportService.Generate(snapshotResult, suppressedSnapshot));
            var base64 = Convert.ToBase64String(pdfBytes);
            await _module.InvokeVoidAsync("downloadFile", "improved-sow.pdf", base64);
        }
        finally
        {
            _downloading = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
    }
}
