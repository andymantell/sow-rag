@page "/results/{DocumentId:guid}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<SoWDbContext> DbFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject Microsoft.FeatureManagement.IFeatureManager FeatureManager
@inject EvaluationService Evaluator
@inject ILogger<Results> Logger
@implements IAsyncDisposable

<div class="govuk-width-container">
    <main class="govuk-main-wrapper" id="main-content">
        @if (_result is not null)
        {
            <div class="app-results-toolbar">
                <a href="/" class="govuk-back-link">Back</a>
                @if (_showEditingFeatures)
                {
                    <button class="govuk-button govuk-button--secondary"
                            @onclick="DownloadPdfAsync"
                            disabled="@_downloading">
                        @(_downloading ? "Generating…" : "Download improved document")
                    </button>
                }
            </div>
            <ResultsPanel Result="_result"
                          ShowEditingFeatures="_showEditingFeatures"
                          ShowExplanations="_showExplanations"
                          SuppressedSections="_suppressed"
                          EvaluatingSections="_evaluatingSections"
                          EvaluationMessage="@_evaluationMessage"
                          OnSuppressedChanged="SaveSuppressedAsync"
                          OnSectionEdited="HandleSectionEdited"
                          OnVersionRestored="HandleVersionRestored"
                          OnVersionPreviewRequested="HandleVersionPreviewRequested"
                          OnPreviewCleared="ClearPreview"
                          VersionHistory="_versionHistory"
                          PreviewSectionIndex="_previewSectionIndex"
                          PreviewVersionNumber="_previewVersionNumber"
                          PreviewContent="@_previewContent" />
        }
    </main>
</div>

@code {
    [Parameter] public Guid DocumentId { get; set; }

    private bool _showEditingFeatures;
    private bool _showExplanations;

    private IJSObjectReference? _module;
    private bool _downloading;
    private ImprovementResult? _result;
    private List<SectionEntity>? _sections;
    private readonly HashSet<int> _suppressed = [];
    private Dictionary<int, List<SectionVersionInfo>> _versionHistory = [];

    // Version preview state
    private int? _previewSectionIndex;
    private int? _previewVersionNumber;
    private string? _previewContent;

    // Evaluation state
    private readonly HashSet<int> _evaluatingSections = [];
    private string? _evaluationMessage;
    private CancellationTokenSource? _evalCts;

    protected override async Task OnInitializedAsync()
    {
        _showEditingFeatures = await FeatureManager.IsEnabledAsync("EditingFeatures");
        _showExplanations = await FeatureManager.IsEnabledAsync("Explanations");

        await using var db = await DbFactory.CreateDbContextAsync();
        _sections = await db.Sections
            .Where(s => s.DocumentId == DocumentId)
            .Include(s => s.Versions)
            .OrderBy(s => s.SectionIndex)
            .ToListAsync();

        if (_sections.Count == 0)
        {
            Nav.NavigateTo("/", replace: true);
            return;
        }

        _result = new ImprovementResult
        {
            Sections = _sections.Select(s => new SectionResult
            {
                OriginalTitle = s.OriginalTitle,
                OriginalContent = s.OriginalContent,
                ImprovedContent = s.ImprovedContent,
                BaselineContent = s.BaselineContent,
                MatchedSection = s.MatchedSection,
                Explanation = s.Explanation,
                Unrecognised = s.Unrecognised,
                VersionCount = s.Versions.Count,
                OriginalQualityScore = s.OriginalQualityScore,
                BaselineQualityScore = s.BaselineQualityScore,
                RagQualityScore = s.RagQualityScore,
                BaselineFaithfulnessScore = s.BaselineFaithfulnessScore,
                RagFaithfulnessScore = s.RagFaithfulnessScore,
                ContextPrecisionScore = s.ContextPrecisionScore
            }).ToList()
        };

        foreach (var s in _sections.Where(s => s.Suppressed))
            _suppressed.Add(s.SectionIndex);

        _versionHistory = _sections.ToDictionary(
            s => s.SectionIndex,
            s => s.Versions
                .OrderBy(v => v.VersionNumber)
                .Select(v => new SectionVersionInfo(v.VersionNumber, v.CreatedAt))
                .ToList());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./Components/Pages/Results.razor.js");

            if (await FeatureManager.IsEnabledAsync("Evaluation"))
                _ = RunEvaluationAsync();
        }
    }

    private async Task RunEvaluationAsync()
    {
        if (_result is null || _sections is null) return;

        // Build list of sections needing evaluation (recognised, have baseline, no scores yet)
        var toEvaluate = new List<(int ResultIndex, SectionEntity Entity)>();
        for (var i = 0; i < _result.Sections.Count; i++)
        {
            var sec = _result.Sections[i];
            var entity = _sections[i];
            if (!sec.Unrecognised && sec.BaselineContent is not null && !sec.RagQualityScore.HasValue)
                toEvaluate.Add((i, entity));
        }

        if (toEvaluate.Count == 0) return;

        var evalInputs = toEvaluate.Select(t =>
        {
            var sec = _result.Sections[t.ResultIndex];
            var entity = t.Entity;
            var contexts = entity.RetrievedContextsJson is not null
                ? System.Text.Json.JsonSerializer.Deserialize<List<string>>(entity.RetrievedContextsJson) ?? []
                : [];
            return new EvaluationService.SectionInput
            {
                Original = sec.OriginalContent,
                Baseline = sec.BaselineContent!,
                RagImproved = sec.ImprovedContent!,
                RetrievedContexts = contexts,
                DefinitionOfGood = entity.DefinitionOfGoodText ?? ""
            };
        }).ToList();

        // Mark all as evaluating
        foreach (var (idx, _) in toEvaluate)
            _evaluatingSections.Add(idx);
        _evaluationMessage = $"Scoring section 1 of {toEvaluate.Count}…";
        await InvokeAsync(StateHasChanged);

        _evalCts = new CancellationTokenSource();
        try
        {
            var completed = 0;
            await foreach (var (streamIdx, scores) in Evaluator.EvaluateStreamingAsync(evalInputs, _evalCts.Token))
            {
                if (streamIdx < 0 || streamIdx >= toEvaluate.Count) continue;
                var (resultIdx, entity) = toEvaluate[streamIdx];

                // Update in-memory result
                var sec = _result.Sections[resultIdx];
                sec.OriginalQualityScore = scores.OriginalQualityScore;
                sec.BaselineQualityScore = scores.BaselineQualityScore;
                sec.RagQualityScore = scores.RagQualityScore;
                sec.BaselineFaithfulnessScore = scores.BaselineFaithfulnessScore;
                sec.RagFaithfulnessScore = scores.RagFaithfulnessScore;
                sec.ContextPrecisionScore = scores.ContextPrecisionScore;

                // Persist to DB
                entity.OriginalQualityScore = scores.OriginalQualityScore;
                entity.BaselineQualityScore = scores.BaselineQualityScore;
                entity.RagQualityScore = scores.RagQualityScore;
                entity.BaselineFaithfulnessScore = scores.BaselineFaithfulnessScore;
                entity.RagFaithfulnessScore = scores.RagFaithfulnessScore;
                entity.ContextPrecisionScore = scores.ContextPrecisionScore;

                await using var db = await DbFactory.CreateDbContextAsync();
                db.Attach(entity);
                db.Entry(entity).Property(s => s.OriginalQualityScore).IsModified = true;
                db.Entry(entity).Property(s => s.BaselineQualityScore).IsModified = true;
                db.Entry(entity).Property(s => s.RagQualityScore).IsModified = true;
                db.Entry(entity).Property(s => s.BaselineFaithfulnessScore).IsModified = true;
                db.Entry(entity).Property(s => s.RagFaithfulnessScore).IsModified = true;
                db.Entry(entity).Property(s => s.ContextPrecisionScore).IsModified = true;
                await db.SaveChangesAsync();

                _evaluatingSections.Remove(resultIdx);
                completed++;
                _evaluationMessage = completed < toEvaluate.Count
                    ? $"Scoring section {completed + 1} of {toEvaluate.Count}…"
                    : null;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Evaluation failed for remaining sections");
        }
        finally
        {
            _evaluatingSections.Clear();
            _evaluationMessage = null;
            await InvokeAsync(StateHasChanged);
            _evalCts?.Dispose();
            _evalCts = null;
        }
    }

    private async Task HandleSectionEdited((int SectionIndex, string NewMarkdown) args)
    {
        var section = _sections!.First(s => s.SectionIndex == args.SectionIndex);
        var nextVersion = section.Versions.Count > 0
            ? section.Versions.Max(v => v.VersionNumber) + 1
            : 1;

        var version = new SectionVersionEntity
        {
            Id = Guid.NewGuid(),
            SectionId = section.Id,
            VersionNumber = nextVersion,
            Content = args.NewMarkdown,
            CreatedAt = DateTime.UtcNow
        };

        section.ImprovedContent = args.NewMarkdown;
        section.Versions.Add(version);

        await using var db = await DbFactory.CreateDbContextAsync();
        db.SectionVersions.Add(version);
        db.Attach(section).Property(s => s.ImprovedContent).IsModified = true;
        await db.SaveChangesAsync();

        _result!.Sections[args.SectionIndex].ImprovedContent = args.NewMarkdown;
        _result.Sections[args.SectionIndex].VersionCount = section.Versions.Count;

        _versionHistory[args.SectionIndex] = section.Versions
            .OrderBy(v => v.VersionNumber)
            .Select(v => new SectionVersionInfo(v.VersionNumber, v.CreatedAt))
            .ToList();
    }

    private async Task HandleVersionRestored((int SectionIndex, int VersionNumber) args)
    {
        var section = _sections!.First(s => s.SectionIndex == args.SectionIndex);
        var sourceVersion = section.Versions.First(v => v.VersionNumber == args.VersionNumber);
        ClearPreview();
        await HandleSectionEdited((args.SectionIndex, sourceVersion.Content));
    }

    private void HandleVersionPreviewRequested((int SectionIndex, int VersionNumber) args)
    {
        var section = _sections!.First(s => s.SectionIndex == args.SectionIndex);
        var version = section.Versions.FirstOrDefault(v => v.VersionNumber == args.VersionNumber);
        if (version is not null)
        {
            _previewSectionIndex = args.SectionIndex;
            _previewVersionNumber = args.VersionNumber;
            _previewContent = version.Content;
        }
    }

    private void ClearPreview()
    {
        _previewSectionIndex = null;
        _previewVersionNumber = null;
        _previewContent = null;
    }

    private async Task SaveSuppressedAsync()
    {
        if (_sections is null) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        foreach (var sec in _sections)
        {
            var shouldSuppress = _suppressed.Contains(sec.SectionIndex);
            if (sec.Suppressed != shouldSuppress)
            {
                sec.Suppressed = shouldSuppress;
                db.Attach(sec).Property(s => s.Suppressed).IsModified = true;
            }
        }
        await db.SaveChangesAsync();
    }

    private async Task DownloadPdfAsync()
    {
        if (_result is null || _module is null) return;

        _downloading = true;
        try
        {
            var suppressedSnapshot = _suppressed.ToHashSet();
            // Snapshot section content to avoid mutation during background PDF generation
            var sectionSnapshots = _result.Sections.Select(s => (s.OriginalTitle, s.OriginalContent, s.ImprovedContent, s.Unrecognised)).ToList();
            var snapshotResult = new ImprovementResult
            {
                Sections = sectionSnapshots.Select(s => new SectionResult
                {
                    OriginalTitle = s.OriginalTitle,
                    OriginalContent = s.OriginalContent,
                    ImprovedContent = s.ImprovedContent,
                    Unrecognised = s.Unrecognised
                }).ToList()
            };
            var pdfBytes = await Task.Run(() => PdfExportService.Generate(snapshotResult, suppressedSnapshot));
            var base64 = Convert.ToBase64String(pdfBytes);
            await _module.InvokeVoidAsync("downloadFile", "improved-sow.pdf", base64);
        }
        finally
        {
            _downloading = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _evalCts?.Cancel();
        _evalCts?.Dispose();
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
    }
}
