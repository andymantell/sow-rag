@page "/"
@rendermode InteractiveServer
@inject IDbContextFactory<SoWDbContext> DbFactory

<div class="govuk-width-container">
    <main class="govuk-main-wrapper" id="main-content">
        <div class="app-prose-width">
            <p class="govuk-body">Upload a statement of work PDF to get an improved version. The tool matches each section of your document against a set of quality standards derived from known-good examples, then rewrites it to improve clarity, completeness and professional tone. Review the suggested changes side by side with your original.</p>
        </div>
        <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">
        <DefinitionSidebar />
        <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">
        <UploadPanel />

        @if (_documents.Count > 0)
        {
            <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">
            <h2 class="govuk-heading-m">Previous documents</h2>
            <table class="govuk-table">
                <thead class="govuk-table__head">
                    <tr class="govuk-table__row">
                        <th class="govuk-table__header" scope="col">Document</th>
                        <th class="govuk-table__header" scope="col">Uploaded</th>
                        <th class="govuk-table__header" scope="col"></th>
                    </tr>
                </thead>
                <tbody class="govuk-table__body">
                    @foreach (var doc in _documents)
                    {
                        <tr class="govuk-table__row">
                            <td class="govuk-table__cell">@doc.FileName</td>
                            <td class="govuk-table__cell">@doc.UploadedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                            <td class="govuk-table__cell">
                                <a href="/results/@doc.Id" class="govuk-link">View results</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </main>
</div>

@code {
    private List<DocumentEntity> _documents = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _documents = await db.Documents
            .OrderByDescending(d => d.UploadedAt)
            .Take(50)
            .AsNoTracking()
            .ToListAsync();
    }
}
