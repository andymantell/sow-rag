@page "/"
@rendermode InteractiveServer
@inject GoodDefinition Definition

<div class="govuk-width-container app-main">
    <main class="govuk-main-wrapper" id="main-content">
        <div class="app-intro">
            <p class="govuk-body">Upload a statement of work PDF to get an improved version. The tool matches each section of your document against a set of quality standards derived from known-good examples, then rewrites it to improve clarity, completeness and professional tone. Review the suggested changes side by side with your original.</p>
        </div>
        <DefinitionSidebar IsDefinitionReady="Definition.IsReady" />
        <UploadPanel OnImproved="HandleImproved" />
        <ResultsPanel Result="_result" />
    </main>
</div>

@code {
    private ImprovementResult? _result;

    private void HandleImproved(ImprovementResult result)
    {
        _result = result;
    }
}
