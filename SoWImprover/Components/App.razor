<!DOCTYPE html>
<html lang="en" class="govuk-template">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1d70b8" />
    <base href="/" />
    <link rel="icon" href="assets/images/favicon.ico" sizes="any" />
    <link rel="icon" href="assets/images/favicon.svg" type="image/svg+xml" />
    <title>Improve a statement of work</title>

    <link rel="stylesheet" href="govuk/govuk-frontend-6.1.0.min.css" />
    <link rel="stylesheet" href="app.css" />

    <HeadOutlet />

</head>
<body class="govuk-template__body">

    <script>document.body.className += ' js-enabled' + ('noModule' in HTMLScriptElement.prototype ? ' govuk-frontend-supported' : '');</script>

    <a href="#main-content" class="govuk-skip-link" data-module="govuk-skip-link">Skip to main content</a>

    <Routes />

    <script type="module">
        import { initAll } from '/govuk/govuk-frontend-6.1.0.min.js';
        initAll();
        // Re-initialise GOV.UK Frontend components after Blazor DOM updates,
        // so dynamically rendered components (error summaries, details, etc.) are enhanced.
        // GOV.UK Frontend v5+ throws InitError on already-initialised components — safe to ignore.
        let pending;
        new MutationObserver(() => {
            clearTimeout(pending);
            pending = setTimeout(() => {
                try { initAll(); } catch (e) { if (e.name !== 'InitError') throw e; }
            }, 100);
        }).observe(document.getElementById('main-content') ?? document.body,
                   { childList: true, subtree: true });
    </script>
    <script src="_framework/blazor.web.js"></script>

</body>
</html>
