@inject GoodDefinition Definition

<div class="app-sidebar @(_collapsed ? "collapsed" : "")">
    <div class="app-sidebar__header">
        <span class="app-sidebar__title">Definition of Good</span>
        <button class="app-sidebar__toggle"
                type="button"
                title="@(_collapsed ? "Expand panel" : "Collapse panel")"
                @onclick="ToggleCollapsed">
            @(_collapsed ? "▶" : "◀")
        </button>
    </div>
    <div class="app-sidebar__body">
        @if (!IsDefinitionReady)
        {
            <div class="app-loading">
                <div class="app-loading__ring"></div>
                <p class="app-loading__text">Generating definition of good…</p>
            </div>
        }
        else
        {
            @_definitionHtml
        }
    </div>
</div>

@code {
    /// <summary>
    /// Passed from Home so Blazor detects the false→true change and calls OnParametersSet,
    /// which triggers the one-time markdown render. Without an explicit parameter, Blazor has
    /// nothing to diff on this component and may skip the lifecycle call.
    /// </summary>
    [Parameter] public bool IsDefinitionReady { get; set; }

    private bool _collapsed;
    private MarkupString _definitionHtml;
    private bool _definitionHtmlComputed;

    protected override void OnParametersSet()
    {
        if (IsDefinitionReady && !_definitionHtmlComputed)
        {
            _definitionHtml = MarkdownRenderer.ToMarkupString(Definition.MarkdownContent);
            _definitionHtmlComputed = true;
        }
    }

    private void ToggleCollapsed() => _collapsed = !_collapsed;
}
