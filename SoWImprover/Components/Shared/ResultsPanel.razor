@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="app-diff-area">

    @if (Result is null)
    {
        <div class="diff-placeholder"></div>
    }
    else
    {
        @* Column headers *@
        <div class="diff-panels">
            <div class="diff-header-row">
                <h2 class="diff-col-header govuk-heading-m">Original</h2>
                <h2 class="diff-col-header govuk-heading-m">Improved (no RAG)</h2>
                <h2 class="diff-col-header govuk-heading-m">Improved (with RAG)</h2>
            </div>

            @* One row per section *@
            @foreach (var (rendered, sectionIndex) in _rendered.Select((r, i) => (r, i)))
            {
                var sec = Result.Sections[sectionIndex];
                var idx = sectionIndex;
                var suppressed = SuppressedSections.Contains(idx);
                // Unrecognised sections start with 0 versions (no LLM output); recognised start with 1
                var hasEdits = sec.Unrecognised ? sec.VersionCount > 0 : sec.VersionCount > 1;
                var isEditing = _editingIndex == idx;
                var isPreviewing = PreviewSectionIndex == idx && PreviewContent is not null;

                <div class="diff-section-row @(sec.Unrecognised ? "diff-section-row--unrecognised" : "") @(suppressed ? "diff-section-row--suppressed" : "")">
                    @* Left: original *@
                    <div class="diff-col">
                        <h3 class="diff-section-heading">@sec.OriginalTitle</h3>
                        @if (!suppressed && !sec.Unrecognised && (EvaluatingSections.Contains(idx) || sec.OriginalQualityScore.HasValue))
                        {
                            <div class="app-score-badges" aria-live="polite">
                                <span class="app-score-badge" style="@BadgeStyle(sec.OriginalQualityScore, max: 5)">
                                    Quality: @ScoreValueQuality(sec.OriginalQualityScore, EvaluatingSections.Contains(idx))
                                    <button type="button" class="app-score-info-btn" aria-label="About quality score">?</button>
                                    <span class="app-score-tooltip" role="tooltip">Baseline quality of the original SoW content before any LLM improvement, scored 1–5 against the definition of good. This is the starting point — compare it to the baseline and RAG columns to see how much each approach improved the section.</span>
                                </span>
                            </div>
                        }
                        @if (!suppressed)
                        {
                            @rendered.OriginalHtml
                        }
                    </div>

                    @* Middle: baseline (no RAG) *@
                    <div class="diff-col">
                        <h3 class="diff-section-heading">@sec.OriginalTitle</h3>
                        @if (suppressed)
                        {
                            <p class="govuk-body app-suppressed-notice">
                                Section excluded from output
                            </p>
                        }
                        else if (sec.Unrecognised)
                        {
                            <p class="govuk-body govuk-body--secondary"><em>Section not recognised</em></p>
                        }
                        else
                        {
                            var baselineEval = EvaluatingSections.Contains(idx);
                            @if (baselineEval || sec.BaselineQualityScore.HasValue || sec.BaselineFaithfulnessScore.HasValue
                                || sec.BaselineFactualCorrectnessScore.HasValue || sec.BaselineResponseRelevancyScore.HasValue)
                            {
                                <div class="app-score-badges" aria-live="polite">
                                    <span class="app-score-badge" style="@BadgeStyle(sec.BaselineQualityScore, max: 5)">
                                        Quality: @ScoreValueQuality(sec.BaselineQualityScore, baselineEval)
                                        <button type="button" class="app-score-info-btn" aria-label="About quality score">?</button>
                                        <span class="app-score-tooltip" role="tooltip">Quality of the prompt-only output (no RAG), scored 1–5 against the definition of good. Compare with the original and RAG columns to see whether adding reference documents produces higher quality improvements than the LLM alone.</span>
                                    </span>
                                    <span class="app-score-badge" style="@BadgeStyle(sec.BaselineFaithfulnessScore)">
                                        Faithfulness: @ScoreValueDecimal(sec.BaselineFaithfulnessScore, baselineEval)
                                        <button type="button" class="app-score-info-btn" aria-label="About faithfulness score">?</button>
                                        <span class="app-score-tooltip" role="tooltip">Did the prompt-only LLM stay true to the original content (0–1)? Breaks the output into individual claims and checks each one against the original. A low score means the LLM hallucinated or invented content without RAG grounding. Compare with the RAG column to see if retrieved documents help reduce hallucination.</span>
                                    </span>
                                    <span class="app-score-badge" style="@BadgeStyle(sec.BaselineFactualCorrectnessScore)">
                                        Factual correctness: @ScoreValueDecimal(sec.BaselineFactualCorrectnessScore, baselineEval)
                                        <button type="button" class="app-score-info-btn" aria-label="About factual correctness score">?</button>
                                        <span class="app-score-tooltip" role="tooltip">How accurately did the prompt-only output preserve the original facts (0–1 F1)? Decomposes both original and output into atomic claims, then measures precision (no invented facts) and recall (no lost facts). Compare with RAG to see if reference documents help the LLM retain more of the original information.</span>
                                    </span>
                                    <span class="app-score-badge" style="@BadgeStyle(sec.BaselineResponseRelevancyScore)">
                                        Relevancy: @ScoreValueDecimal(sec.BaselineResponseRelevancyScore, baselineEval)
                                        <button type="button" class="app-score-info-btn" aria-label="About response relevancy score">?</button>
                                        <span class="app-score-tooltip" role="tooltip">Did the prompt-only output stay on-task (0–1)? Generates questions from the output and checks if they align with the original improvement request. A low score means the LLM went off-topic. Compare with RAG to see if reference documents help keep the output focused.</span>
                                    </span>
                                </div>
                            }
                            @rendered.BaselineHtml
                        }
                    </div>

                    @* Right: improved (with RAG) / edit / preview *@
                    <div class="diff-col">
                        @if (suppressed)
                        {
                            <div class="diff-section-heading-row">
                                <h3 class="diff-section-heading">@sec.OriginalTitle</h3>
                                @if (ShowEditingFeatures)
                                {
                                    <button class="govuk-button govuk-button--secondary app-section-btn"
                                            @onclick="() => ToggleSection(idx)">
                                        Include section
                                    </button>
                                }
                            </div>
                            <p class="govuk-body app-suppressed-notice">
                                Section excluded from output
                            </p>
                        }
                        else if (ShowEditingFeatures && isEditing)
                        {
                            @* ── Edit mode ── *@
                            <div class="diff-section-heading-row">
                                <h3 class="diff-section-heading">@sec.OriginalTitle</h3>
                            </div>
                            <div class="app-editor-toolbar" id="toolbar-@idx">
                                <div class="toolbar-group">
                                    <button data-cmd="toggleBold" aria-label="Bold" title="Bold"><b>B</b></button>
                                    <button data-cmd="toggleItalic" aria-label="Italic" title="Italic"><i>I</i></button>
                                    <button data-cmd="toggleHeading" aria-label="Heading" title="Heading">H</button>
                                </div>
                                <div class="toolbar-group">
                                    <button data-cmd="toggleBulletList" aria-label="Bullet list" title="Bullet list">•</button>
                                    <button data-cmd="toggleOrderedList" aria-label="Numbered list" title="Numbered list">1.</button>
                                </div>
                                <div class="toolbar-group">
                                    <button data-cmd="insertTable" aria-label="Insert table" title="Insert table">⊞</button>
                                    <button data-cmd="addRowAfter" aria-label="Add row" title="Add row">+Row</button>
                                    <button data-cmd="deleteRow" aria-label="Delete row" title="Delete row">−Row</button>
                                    <button data-cmd="addColumnAfter" aria-label="Add column" title="Add column">+Col</button>
                                    <button data-cmd="deleteColumn" aria-label="Delete column" title="Delete column">−Col</button>
                                </div>
                            </div>
                            <div class="app-editor-container">
                                <div id="editor-@idx"></div>
                            </div>
                            <div class="app-editor-actions">
                                <button class="govuk-button" @onclick="() => SaveEdit(idx)">Save</button>
                                <button class="govuk-button govuk-button--secondary" @onclick="() => CancelEdit(idx)">Cancel</button>
                            </div>
                        }
                        else
                        {
                            @* ── View mode ── *@
                            <div class="diff-section-heading-row">
                                <h3 class="diff-section-heading">@sec.OriginalTitle</h3>
                                @if (ShowEditingFeatures)
                                {
                                    <div class="app-section-actions">
                                        <button class="govuk-button govuk-button--secondary app-section-btn"
                                                disabled="@(_editorModule is null)"
                                                @onclick="() => StartEditing(idx)">
                                            Edit
                                        </button>
                                        <button class="govuk-button govuk-button--warning app-section-btn"
                                                @onclick="() => ToggleSection(idx)">
                                            Exclude section
                                        </button>
                                    </div>
                                }
                            </div>

                            @if (ShowEditingFeatures)
                            {
                                @* ── Version switcher ── *@
                                @if (VersionHistory.TryGetValue(idx, out var versions) && versions.Count > 1)
                                {
                                    var currentVersion = versions.Max(v => v.VersionNumber);
                                    var selectedVersion = (PreviewSectionIndex == idx && PreviewVersionNumber.HasValue)
                                        ? PreviewVersionNumber.Value : currentVersion;
                                    <div class="app-version-switcher">
                                        <select class="govuk-select app-version-select"
                                                value="@selectedVersion"
                                                @onchange="async (e) => { if (int.TryParse(e.Value?.ToString(), out var v)) await OnVersionSelectChanged(idx, v, currentVersion); }">
                                            @foreach (var v in versions.OrderByDescending(x => x.VersionNumber))
                                            {
                                                var label = v.VersionNumber == currentVersion
                                                    ? $"Version {v.VersionNumber} (current)"
                                                    : $"Version {v.VersionNumber} — {v.CreatedAt.ToLocalTime():d MMM yyyy HH:mm}";
                                                <option value="@v.VersionNumber">@label</option>
                                            }
                                        </select>
                                        @if (isPreviewing)
                                        {
                                            <button class="govuk-button govuk-button--secondary app-section-btn"
                                                    @onclick="() => OnVersionRestored.InvokeAsync((idx, PreviewVersionNumber!.Value))">
                                                Restore this version
                                            </button>
                                        }
                                    </div>
                                }
                            }

                            @* ── Content area ── *@
                            @if (isPreviewing)
                            {
                                @* XSS safe: MarkdownRenderer uses Markdig .DisableHtml() *@
                                @MarkdownRenderer.ToMarkupString(PreviewContent!)
                            }
                            else if (sec.Unrecognised)
                            {
                                @if (!hasEdits)
                                {
                                    var unrecognisedId = $"nb-unrecognised-{sectionIndex}";
                                    <div class="govuk-notification-banner govuk-notification-banner--warning app-explanation-banner"
                                         role="region"
                                         aria-labelledby="@unrecognisedId"
                                         data-module="govuk-notification-banner">
                                        <div class="govuk-notification-banner__header">
                                            <h2 class="govuk-notification-banner__title" id="@unrecognisedId">Section not recognised</h2>
                                        </div>
                                        <div class="govuk-notification-banner__content">
                                            <p class="govuk-body">This section could not be matched to the definition of good - no improvements have been made.</p>
                                        </div>
                                    </div>
                                }
                                @if (hasEdits)
                                {
                                    @rendered.ImprovedHtml
                                }
                                else
                                {
                                    @rendered.OriginalHtml
                                }
                            }
                            else
                            {
                                @* ── What-changed banner ── *@
                                @if (ShowExplanations && (rendered.BulletHtml.Count > 0 || rendered.ExplanationHtml.HasValue))
                                {
                                    var summaryText = "What changed" + (string.IsNullOrWhiteSpace(sec.MatchedSection) ? "" : $" (improved using {sec.MatchedSection})");

                                    <details class="govuk-details" data-module="govuk-details" open="@(!hasEdits ? true : (bool?)null)">
                                        <summary class="govuk-details__summary">
                                            <span class="govuk-details__summary-text">@summaryText</span>
                                        </summary>
                                        <div class="govuk-details__text">
                                            @if (rendered.BulletHtml.Count > 0)
                                            {
                                                <ul class="govuk-list govuk-list--bullet">
                                                    @foreach (var bullet in rendered.BulletHtml)
                                                    {
                                                        <li>@bullet</li>
                                                    }
                                                </ul>
                                            }
                                            else if (rendered.ExplanationHtml.HasValue)
                                            {
                                                <p class="govuk-body">@rendered.ExplanationHtml.Value</p>
                                            }
                                        </div>
                                    </details>
                                }
                                @if (EvaluatingSections.Contains(idx) || sec.RagQualityScore.HasValue || sec.RagFaithfulnessScore.HasValue || sec.ContextPrecisionScore.HasValue
                                    || sec.RagFactualCorrectnessScore.HasValue || sec.ContextRecallScore.HasValue
                                    || sec.RagResponseRelevancyScore.HasValue || sec.NoiseSensitivityScore.HasValue)
                                {
                                    var ragEval = EvaluatingSections.Contains(idx);
                                    <div class="app-score-badges" aria-live="polite">
                                        <span class="app-score-badge" style="@BadgeStyle(sec.RagQualityScore, max: 5)">
                                            Quality: @ScoreValueQuality(sec.RagQualityScore, ragEval)
                                            <button type="button" class="app-score-info-btn" aria-label="About quality score">?</button>
                                            <span class="app-score-tooltip" role="tooltip">Quality of the RAG-enhanced output, scored 1–5 against the definition of good. This is the key comparison — if RAG is adding value, this score should be higher than both the original and the prompt-only baseline.</span>
                                        </span>
                                        <span class="app-score-badge" style="@BadgeStyle(sec.RagFaithfulnessScore)">
                                            Faithfulness: @ScoreValueDecimal(sec.RagFaithfulnessScore, ragEval)
                                            <button type="button" class="app-score-info-btn" aria-label="About faithfulness score">?</button>
                                            <span class="app-score-tooltip" role="tooltip">Did the RAG-enhanced output stay true to the original content (0–1)? Breaks the output into claims and checks each against the original. If this is higher than the baseline column, RAG is helping the LLM hallucinate less by grounding it with reference documents.</span>
                                        </span>
                                        <span class="app-score-badge" style="@BadgeStyle(sec.RagFactualCorrectnessScore)">
                                            Factual correctness: @ScoreValueDecimal(sec.RagFactualCorrectnessScore, ragEval)
                                            <button type="button" class="app-score-info-btn" aria-label="About factual correctness score">?</button>
                                            <span class="app-score-tooltip" role="tooltip">How accurately did the RAG output preserve the original facts (0–1 F1)? Decomposes both texts into atomic claims, measuring precision (nothing invented) and recall (nothing lost). Higher than baseline means RAG helped retain more original information while adding fewer fabrications.</span>
                                        </span>
                                        <span class="app-score-badge" style="@BadgeStyle(sec.RagResponseRelevancyScore)">
                                            Relevancy: @ScoreValueDecimal(sec.RagResponseRelevancyScore, ragEval)
                                            <button type="button" class="app-score-info-btn" aria-label="About response relevancy score">?</button>
                                            <span class="app-score-tooltip" role="tooltip">Did the RAG output stay on-task (0–1)? Generates questions from the output and checks if they match the original improvement request. If lower than baseline, the retrieved documents may be distracting the LLM from the core task.</span>
                                        </span>
                                        <span class="app-score-badge" style="@BadgeStyle(sec.ContextPrecisionScore)">
                                            Context precision: @ScoreValueDecimal(sec.ContextPrecisionScore, ragEval)
                                            <button type="button" class="app-score-info-btn" aria-label="About context precision score">?</button>
                                            <span class="app-score-tooltip" role="tooltip">Were the retrieved reference chunks actually relevant (0–1)? Evaluates each chunk the retriever found and checks whether it was useful for improving this section. A low score means the retriever is pulling in irrelevant material, which may explain poor RAG performance.</span>
                                        </span>
                                        <span class="app-score-badge" style="@BadgeStyle(sec.ContextRecallScore)">
                                            Context recall: @ScoreValueDecimal(sec.ContextRecallScore, ragEval)
                                            <button type="button" class="app-score-info-btn" aria-label="About context recall score">?</button>
                                            <span class="app-score-tooltip" role="tooltip">Did retrieval find everything it needed (0–1)? Checks whether the retrieved chunks cover all the important information from the original section. A low score means the retriever missed relevant reference material — the corpus may need more documents, or the chunking/embedding strategy needs tuning.</span>
                                        </span>
                                        <span class="app-score-badge" style="@BadgeStyle(sec.NoiseSensitivityScore, lowerIsBetter: true)">
                                            Noise sensitivity: @ScoreValueDecimal(sec.NoiseSensitivityScore, ragEval, lowerIsBetter: true)
                                            <button type="button" class="app-score-info-btn" aria-label="About noise sensitivity score">?</button>
                                            <span class="app-score-tooltip" role="tooltip">Is irrelevant retrieved content actively harming the output (0–1)? Lower is better. Checks whether incorrect claims in the output can be traced back to irrelevant chunks. A high score means the retriever is injecting noise that the LLM is then incorporating — this is where RAG can perform worse than prompt-only.</span>
                                        </span>
                                    </div>
                                }
                                @rendered.ImprovedHtml
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }

</div>

@code {
    [Parameter] public ImprovementResult? Result { get; set; }
    [Parameter] public bool ShowEditingFeatures { get; set; }
    [Parameter] public bool ShowExplanations { get; set; }
    [Parameter] public HashSet<int> SuppressedSections { get; set; } = [];
    [Parameter] public HashSet<int> EvaluatingSections { get; set; } = [];
    [Parameter] public EventCallback OnSuppressedChanged { get; set; }
    [Parameter] public EventCallback<(int SectionIndex, string NewMarkdown)> OnSectionEdited { get; set; }
    [Parameter] public EventCallback<(int SectionIndex, int VersionNumber)> OnVersionRestored { get; set; }
    [Parameter] public EventCallback<(int SectionIndex, int VersionNumber)> OnVersionPreviewRequested { get; set; }
    [Parameter] public EventCallback OnPreviewCleared { get; set; }
    [Parameter] public Dictionary<int, List<SectionVersionInfo>> VersionHistory { get; set; } = [];
    [Parameter] public int? PreviewSectionIndex { get; set; }
    [Parameter] public int? PreviewVersionNumber { get; set; }
    [Parameter] public string? PreviewContent { get; set; }

    private record RenderedSection(
        MarkupString OriginalHtml,
        MarkupString BaselineHtml,
        MarkupString ImprovedHtml,
        List<MarkupString> BulletHtml,
        MarkupString? ExplanationHtml);

    private ImprovementResult? _lastResult;
    private List<RenderedSection> _rendered = [];
    private List<string?> _renderedContent = [];
    private int? _editingIndex;
    private IJSObjectReference? _editorModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ShowEditingFeatures)
        {
            _editorModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./Components/Shared/ResultsPanel.razor.js");
            StateHasChanged();
        }
    }

    protected override void OnParametersSet()
    {
        if (Result is null) { _rendered = []; _renderedContent = []; return; }

        if (Result != _lastResult)
        {
            _lastResult = Result;
            _rendered = Result.Sections.Select(RenderSection).ToList();
            _renderedContent = Result.Sections.Select(s => s.ImprovedContent).ToList();
        }
        else
        {
            // Re-render any sections whose content changed in-place (e.g. after restore)
            for (var i = 0; i < Result.Sections.Count; i++)
            {
                if (Result.Sections[i].ImprovedContent != _renderedContent[i])
                {
                    _rendered[i] = RenderSection(Result.Sections[i]);
                    _renderedContent[i] = Result.Sections[i].ImprovedContent;
                }
            }
        }
    }

    private RenderedSection RenderSection(SectionResult sec)
    {
        var bullets = (sec.Explanation ?? "")
            .Split('\n')
            .Select(l => l.Trim())
            .Where(l => l.StartsWith("-"))
            .Select(l => MarkdownRenderer.ToInlineMarkupString(l[1..].Trim()))
            .ToList();

        MarkupString? explanationHtml = bullets.Count == 0 && !string.IsNullOrWhiteSpace(sec.Explanation)
            ? MarkdownRenderer.ToInlineMarkupString(sec.Explanation)
            : null;

        return new RenderedSection(
            MarkdownRenderer.ToMarkupString(sec.OriginalContent),
            MarkdownRenderer.ToMarkupString(sec.BaselineContent ?? ""),
            MarkdownRenderer.ToMarkupString(sec.ImprovedContent ?? ""),
            bullets,
            explanationHtml);
    }

    /// <summary>Returns inline badge style: coloured when value present, neutral grey when loading/error.</summary>
    private static string BadgeStyle(double? score, bool lowerIsBetter = false, double max = 1.0)
    {
        if (!score.HasValue)
            return "";
        var normalised = Math.Clamp(score.Value / max, 0.0, 1.0);
        if (lowerIsBetter) normalised = 1.0 - normalised;
        var hue = (int)(normalised * 120);
        return $"background:hsl({hue},55%,88%);border-color:hsl({hue},35%,72%)";
    }

    private static string BadgeStyle(int? score, double max = 5.0)
        => BadgeStyle(score.HasValue ? (double)score.Value : null, max: max);

    /// <summary>Renders score value for 1-5 quality badges: spinner, value, or error cross.</summary>
    private static RenderFragment ScoreValueQuality(int? score, bool evaluating) => builder =>
    {
        if (score.HasValue)
        {
            builder.OpenElement(0, "strong");
            builder.AddContent(1, $"{score}/5");
            builder.CloseElement();
        }
        else if (evaluating)
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "app-badge-spinner");
            builder.AddAttribute(2, "aria-label", "Loading");
            builder.CloseElement();
        }
        else
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "app-badge-error");
            builder.AddAttribute(2, "title", "Scoring failed");
            builder.AddContent(3, "\u2717");
            builder.CloseElement();
        }
    };

    /// <summary>Renders score value for 0-1 decimal badges: spinner, value, or error cross.</summary>
    private static RenderFragment ScoreValueDecimal(double? score, bool evaluating, bool lowerIsBetter = false) => builder =>
    {
        if (score.HasValue)
        {
            builder.OpenElement(0, "strong");
            builder.AddContent(1, $"{score:F2}");
            builder.CloseElement();
        }
        else if (evaluating)
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "app-badge-spinner");
            builder.AddAttribute(2, "aria-label", "Loading");
            builder.CloseElement();
        }
        else
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "app-badge-error");
            builder.AddAttribute(2, "title", "Scoring failed");
            builder.AddContent(3, "\u2717");
            builder.CloseElement();
        }
    };

    private void UpdateRenderedSection(int index)
    {
        _rendered[index] = RenderSection(Result!.Sections[index]);
    }

    private async Task StartEditing(int index)
    {
        _editingIndex = index;
        await OnPreviewCleared.InvokeAsync();
        StateHasChanged();

        await Task.Yield();
        if (_editorModule is not null)
        {
            var sec = Result!.Sections[index];
            var markdown = sec.ImprovedContent ?? sec.OriginalContent;
            await _editorModule.InvokeAsync<bool>("createEditor", $"editor-{index}", markdown);
        }
    }

    private async Task SaveEdit(int index)
    {
        if (_editorModule is null) return;

        var markdown = await _editorModule.InvokeAsync<string>("getMarkdown", $"editor-{index}");
        await _editorModule.InvokeVoidAsync("destroyEditor", $"editor-{index}");
        _editingIndex = null;

        if (markdown is not null)
        {
            Result!.Sections[index].ImprovedContent = markdown;
            UpdateRenderedSection(index);
            await OnSectionEdited.InvokeAsync((index, markdown));
        }
    }

    private async Task CancelEdit(int index)
    {
        if (_editorModule is not null)
        {
            var dirty = await _editorModule.InvokeAsync<bool>("hasUnsavedChanges", $"editor-{index}");
            if (dirty)
            {
                var confirmed = await JS.InvokeAsync<bool>("confirm", "You have unsaved changes. Discard them?");
                if (!confirmed) return;
            }
            await _editorModule.InvokeVoidAsync("destroyEditor", $"editor-{index}");
        }
        _editingIndex = null;
    }

    private async Task ToggleSection(int index)
    {
        if (!SuppressedSections.Remove(index))
            SuppressedSections.Add(index);
        await OnSuppressedChanged.InvokeAsync();
    }

    private async Task OnVersionSelectChanged(int sectionIndex, int versionNumber, int currentVersion)
    {
        if (versionNumber == currentVersion)
            await OnPreviewCleared.InvokeAsync();
        else
            await OnVersionPreviewRequested.InvokeAsync((sectionIndex, versionNumber));
    }

    public async ValueTask DisposeAsync()
    {
        if (_editorModule is not null)
        {
            try { await _editorModule.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
    }
}
