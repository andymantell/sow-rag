<div class="app-diff-area">

    @if (Result is null)
    {
        <div class="diff-placeholder">
            <p class="govuk-body-l">Upload a SoW PDF and click <strong>Improve document</strong> to see results.</p>
        </div>
    }
    else
    {
        @* Sources collapsible *@
        @if (Result.ChunksUsed.Count > 0)
        {
            <div class="app-sources">
                <details class="govuk-details">
                    <summary class="govuk-details__summary">
                        <span class="govuk-details__summary-text">Sources used from corpus</span>
                    </summary>
                    <div class="govuk-details__text">
                        @foreach (var chunk in Result.ChunksUsed)
                        {
                            <div class="source-item">
                                <strong>@chunk.SourceFile</strong><br />
                                @chunk.Snippet
                            </div>
                        }
                    </div>
                </details>
            </div>
        }

        @* Column headers *@
        <div class="diff-panels">
            <div class="diff-header-row">
                <div class="diff-col-header">Original</div>
                <div class="diff-col-header">Improved</div>
            </div>

            @* One row per section *@
            @foreach (var sec in Result.Sections)
            {
                <div class="diff-section-row @(sec.Unrecognised ? "diff-section-row--unrecognised" : "")">
                    @* Left: original *@
                    <div class="diff-col">
                        <h3 class="diff-section-heading">@sec.OriginalTitle</h3>
                        @MarkdownRenderer.ToMarkupString(sec.OriginalContent)
                    </div>

                    @* Right: improved or unrecognised notice *@
                    <div class="diff-col">
                        @if (sec.Unrecognised)
                        {
                            <h3 class="diff-section-heading">@sec.OriginalTitle</h3>
                            <div class="diff-unrecognised-notice">
                                <span class="diff-unrecognised-icon" aria-hidden="true">&#9888;</span>
                                Section not recognised — no improvements made.
                            </div>
                            @MarkdownRenderer.ToMarkupString(sec.OriginalContent)
                        }
                        else
                        {
                            <h3 class="diff-section-heading">@sec.OriginalTitle</h3>
                            @MarkdownRenderer.ToMarkupString(sec.ImprovedContent ?? "")
                            @if (!string.IsNullOrWhiteSpace(sec.Explanation))
                            {
                                <details class="govuk-details diff-explanation">
                                    <summary class="govuk-details__summary">
                                        <span class="govuk-details__summary-text">What was improved</span>
                                    </summary>
                                    <div class="govuk-details__text">
                                        @{
                                            var bullets = sec.Explanation
                                                .Split('\n')
                                                .Select(l => l.Trim())
                                                .Where(l => l.StartsWith("-"))
                                                .Select(l => l[1..].Trim())
                                                .ToList();
                                        }
                                        @if (bullets.Count > 0)
                                        {
                                            <ul class="annotation-item__bullets">
                                                @foreach (var b in bullets)
                                                {
                                                    <li>@b</li>
                                                }
                                            </ul>
                                        }
                                        else
                                        {
                                            <p>@sec.Explanation</p>
                                        }
                                    </div>
                                </details>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }

</div>

@code {
    [Parameter] public ImprovementResult? Result { get; set; }
}
