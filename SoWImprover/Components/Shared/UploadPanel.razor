@inject GoodDefinition Definition
@inject DocumentLoader DocumentLoader
@inject SoWImproverService Improver

<form @onsubmit="HandleImproveClicked" @onsubmit:preventDefault>

@if (_errors.Count > 0)
{
    <div class="govuk-error-summary" data-module="govuk-error-summary">
        <div role="alert">
            <h2 class="govuk-error-summary__title">
                There is a problem
            </h2>
            <div class="govuk-error-summary__body">
                <ul class="govuk-list govuk-error-summary__list">
                    @foreach (var (fieldId, message) in _errors)
                    {
                        <li>
                            @if (fieldId is not null)
                            {
                                <a href="#@fieldId">@message</a>
                            }
                            else
                            {
                                @message
                            }
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
}

<div class="@_formGroupClass">
    <label class="govuk-label" for="file-input">
        Upload SoW PDF
    </label>
    @if (_fileError is not null)
    {
        <p id="file-input-error" class="govuk-error-message">
            <span class="govuk-visually-hidden">Error:</span> @_fileError
        </p>
    }
    <InputFile id="file-input"
               name="file-input"
               class="@_fileInputClass"
               accept="application/pdf"
               aria-describedby="@(_fileError is not null ? "file-input-error" : null)"
               OnChange="HandleFileSelected" />
</div>

<button class="govuk-button"
        data-module="govuk-button"
        type="submit">
    Improve document
</button>

@if (_isImproving)
{
    <div class="app-definition-loading">
        <div class="app-spinner" aria-hidden="true"></div>
        <span class="govuk-body-s">@(string.IsNullOrEmpty(_progressMessage) ? "Improving document..." : _progressMessage)</span>
    </div>
}

</form>

@code {
    private const long MaxUploadBytes = 28 * 1024 * 1024;

    [Parameter] public EventCallback<ImprovementResult> OnImproved { get; set; }

    private IBrowserFile? _selectedFile;
    private bool _isImproving;
    private string _progressMessage = "";

    // Each entry is (fieldId, message). fieldId is null for errors not tied to a field.
    private List<(string? FieldId, string Message)> _errors = new();

    private string? _fileError =>
        _errors.Find(e => e.FieldId == "file-input") is { Message: var m } ? m : null;

    private string _formGroupClass =>
        _fileError is not null ? "govuk-form-group govuk-form-group--error" : "govuk-form-group";

    private string _fileInputClass =>
        _fileError is not null ? "govuk-file-upload govuk-file-upload--error" : "govuk-file-upload";

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _errors.RemoveAll(e => e.FieldId == "file-input");
    }

    private bool Validate()
    {
        _errors.Clear();

        if (_selectedFile is null)
            _errors.Add(("file-input", "Select a PDF to upload"));

        if (!Definition.IsReady)
            _errors.Add((null, "The service is still loading - please wait a moment before trying again"));

        return _errors.Count == 0;
    }

    private async Task HandleImproveClicked()
    {
        if (!Validate()) return;

        _isImproving = true;
        _progressMessage = "";
        StateHasChanged();

        var tempPath = Path.Combine(Path.GetTempPath(), $"sow_{Guid.NewGuid():N}.pdf");
        ImprovementResult? result = null;
        try
        {
            using (var fs = File.Create(tempPath))
            await using (var stream = _selectedFile!.OpenReadStream(MaxUploadBytes))
                await stream.CopyToAsync(fs);

            var originalText = (await DocumentLoader.ExtractTextAsync(tempPath)).Trim();

            if (string.IsNullOrWhiteSpace(originalText))
            {
                _errors.Add(("file-input", "No text could be extracted - the PDF may be scanned or image-based"));
                return;
            }

            var progress = new Progress<string>(msg =>
            {
                _progressMessage = msg;
                InvokeAsync(StateHasChanged);
            });
            result = await Improver.ImproveAsync(originalText, Definition, progress);
        }
        catch (Exception ex)
        {
            _errors.Add((null, $"Something went wrong: {ex.Message}"));
        }
        finally
        {
            if (File.Exists(tempPath)) File.Delete(tempPath);
            _isImproving = false;
            _progressMessage = "";
            StateHasChanged();
        }

        if (result is not null)
            await OnImproved.InvokeAsync(result);
    }
}
